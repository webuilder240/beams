#!/usr/bin/env ruby
# frozen_string_literal: true

# Thin host-side wrapper around Beams::Once::Updater.
#
# Runs under the host's system ruby (stdlib only) — does NOT require bundler or
# config/environment. Intended to be invoked by deploy/once/once-update.service
# (systemd timer) or manually.

require_relative "../lib/beams/once/updater"

result = Beams::Once::Updater.new.update!

if result[:updated]
  puts "Beams updated: #{result[:current]} -> #{result[:latest]}"
else
  puts "Beams already up to date (#{result[:latest]})"
end
