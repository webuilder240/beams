<%# local: connection, url, method, submit_label, persisted %>
<%= form_with model: connection, url: url, method: method, local: true, class: "space-y-4" do |f| %>
  <%= render "errors", connection: connection %>

  <div>
    <%= f.label :name, "接続名", class: "form-label" %>
    <%= f.text_field :name, class: "form-input" %>
  </div>

  <div>
    <%= f.label :project_id, "プロジェクト ID", class: "form-label" %>
    <%= f.text_field :project_id, class: "form-input" %>
    <p class="text-xs text-gray-500 mt-1">英数字とハイフンのみ（例: my-project-123）</p>
  </div>

  <div>
    <%= f.label :service_account_json, "サービスアカウント JSON 鍵", class: "form-label" %>
    <%#
      セキュリティ: 暗号化済みの SA JSON 平文は編集画面でも再表示しない。
      value: "" で常に空欄を表示し、編集時は「変更する場合のみ入力」運用とする。
    %>
    <%= f.text_area :service_account_json, value: "", rows: 8,
          placeholder: persisted ? "変更する場合のみ、新しい JSON 鍵を貼り付けてください（空欄なら既存の鍵を保持）" : "サービスアカウントの JSON 鍵を貼り付けてください",
          class: "form-input font-mono" %>
  </div>

  <div>
    <%= f.label :maximum_bytes_billed_gb, "コスト上限（GB・任意）", class: "form-label" %>
    <%= f.number_field :maximum_bytes_billed_gb, min: 0, step: "0.01",
          class: "form-input" %>
    <p class="text-xs text-gray-500 mt-1">
      空欄で上限なし。クエリ単位のスキャン量上限（GB）。1 GB = 1024³ bytes として保存します。
      <% if connection.maximum_bytes_billed.present? %>
        <br>現在の上限: <%= connection.maximum_bytes_billed_gb %> GB（= <%= number_with_delimiter(connection.maximum_bytes_billed) %> bytes）
      <% end %>
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label,
          class: "btn-primary" %>
    <%= link_to "キャンセル", bigquery_connections_path, class: "text-gray-600 hover:underline" %>
  </div>
<% end %>
