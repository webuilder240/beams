<%# local: connection, url, method, submit_label, persisted %>
<%= form_with model: connection, url: url, method: method, local: true, class: "space-y-4" do |f| %>
  <%= render "errors", connection: connection %>

  <div>
    <%= f.label :name, "接続名", class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :project_id, "プロジェクト ID", class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :project_id, class: "w-full rounded border border-gray-300 px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">英数字とハイフンのみ（例: my-project-123）</p>
  </div>

  <div>
    <%= f.label :service_account_json, "サービスアカウント JSON 鍵", class: "block text-sm font-medium mb-1" %>
    <%#
      セキュリティ: 暗号化済みの SA JSON 平文は編集画面でも再表示しない。
      value: "" で常に空欄を表示し、編集時は「変更する場合のみ入力」運用とする。
    %>
    <%= f.text_area :service_account_json, value: "", rows: 8,
          placeholder: persisted ? "変更する場合のみ、新しい JSON 鍵を貼り付けてください（空欄なら既存の鍵を保持）" : "サービスアカウントの JSON 鍵を貼り付けてください",
          class: "w-full rounded border border-gray-300 px-3 py-2 font-mono text-sm" %>
  </div>

  <div>
    <%= f.label :maximum_bytes_billed, "コスト上限（バイト・任意）", class: "block text-sm font-medium mb-1" %>
    <%= f.number_field :maximum_bytes_billed, min: 1,
          class: "w-full rounded border border-gray-300 px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">空欄で上限なし。クエリ単位の課金バイト上限。</p>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label,
          class: "rounded bg-blue-600 text-white px-4 py-2 font-medium hover:bg-blue-700" %>
    <%= link_to "キャンセル", bigquery_connections_path, class: "text-gray-600 hover:underline" %>
  </div>
<% end %>
