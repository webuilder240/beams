<% content_for :title, "#{@query.title} — 可視化" %>

<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold"><%= @query.title %> — 可視化</h1>
    <div class="space-x-3 text-sm">
      <%= link_to "クエリへ戻る", query_path(@query), class: "text-gray-600 hover:underline" %>
    </div>
  </div>

  <%= render "visualizations/visualization",
        query: @query,
        visualization: @visualization,
        execution: @query.latest_succeeded_execution,
        columns: result_columns(@query.latest_succeeded_execution) %>
</div>
