<%#
  可視化フレーム本体。Turbo Frame でラップし、フォーム送信（update）後に
  フォーム＋描画エリアをまとめて差し替える。`columns` は結果の列名一覧。
%>
<%= turbo_frame_tag dom_id(visualization.query, :visualization) do %>
  <div class="space-y-4">
    <%# テーブル⇄チャート切替タブ %>
    <div class="flex gap-2 border-b border-gray-200">
      <% %w[table chart].each do |mode| %>
        <%= form_with url: query_visualization_path(query), method: :patch, class: "inline" do %>
          <%= hidden_field_tag "visualization[display_mode]", mode %>
          <% active = visualization.display_mode == mode %>
          <button type="submit"
                  class="px-4 py-2 text-sm font-medium <%= active ? 'border-b-2 border-emerald-600 text-emerald-700' : 'text-gray-500 hover:text-gray-700' %>">
            <%= mode == "table" ? "テーブル" : "チャート" %>
          </button>
        <% end %>
      <% end %>
    </div>

    <%# チャート設定フォーム（チャートモード時のみ表示） %>
    <% if visualization.display_mode == "chart" %>
      <%= form_with model: visualization, url: query_visualization_path(query), method: :patch,
            class: "space-y-3 rounded border border-gray-200 p-4" do |f| %>
        <div>
          <%= f.label :chart_type, "チャート種別", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :chart_type,
                Visualization::CHART_TYPES.map { |t| [ t, t ] },
                {}, class: "rounded border-gray-300 text-sm",
                data: { chart_settings_target: "chartType" } %>
        </div>

        <%# counter 以外: 軸設定 UI %>
        <div data-counter-hidden="<%= visualization.chart_type == 'counter' %>"
             class="space-y-3 <%= 'hidden' if visualization.chart_type == 'counter' %>">
          <div>
            <%= f.label :x_column, "X軸", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :x_column, columns, { include_blank: "（未選択）" },
                  class: "rounded border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :y_columns, "Y軸（複数選択可）", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :y_columns, columns, {},
                  multiple: true, class: "rounded border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :series_column, "系列", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :series_column, columns, { include_blank: "（なし）" },
                  class: "rounded border-gray-300 text-sm" %>
          </div>
        </div>

        <%# counter: counter_column / counter_aggregation UI（軸とは別系統） %>
        <div data-counter-shown="<%= visualization.chart_type == 'counter' %>"
             class="space-y-3 <%= 'hidden' unless visualization.chart_type == 'counter' %>">
          <div>
            <%= f.label :counter_column, "カウンター対象カラム", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :counter_column, columns, { include_blank: "（未選択）" },
                  class: "rounded border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :counter_aggregation, "集計方法", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :counter_aggregation,
                  Visualization::AGGREGATIONS.map { |a| [ a, a ] },
                  {}, class: "rounded border-gray-300 text-sm" %>
          </div>
        </div>

        <%= f.submit "保存", class: "rounded bg-emerald-600 text-white px-4 py-2 text-sm font-medium hover:bg-emerald-700" %>
      <% end %>
    <% end %>

    <%# 描画エリア %>
    <% if visualization.display_mode == "chart" %>
      <%= render "visualizations/chart", visualization: visualization, execution: execution %>
    <% else %>
      <%= render "visualizations/result_table", execution: execution %>
    <% end %>

    <%# CSV ダウンロード（トピック10 の経路へリンクのみ） %>
    <% if execution.present? %>
      <div class="text-sm">
        <%= link_to "CSVダウンロード",
              latest_csv_query_executions_path(query),
              class: "text-blue-600 hover:underline" %>
      </div>
    <% end %>
  </div>
<% end %>
