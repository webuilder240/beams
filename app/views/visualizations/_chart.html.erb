<%#
  チャート表示パーシャル。counter 以外は Chart.js（Stimulus chart_controller）で
  <canvas> に描画する。counter は単一集計値を大きく表示する（Chart.js 不使用）。
  config が組み立てられない（軸未設定など）場合は案内を出す。
%>
<% if visualization.chart_type == "counter" %>
  <% value = visualization.counter_value(execution) %>
  <div class="rounded border border-gray-200 bg-white px-6 py-10 text-center"
       data-controller="chart" data-chart-type-value="counter">
    <% if value.nil? %>
      <p class="text-sm text-gray-500">カウンター対象カラムを選んでください。</p>
    <% else %>
      <div class="text-5xl font-bold text-gray-900" data-chart-target="counter"><%= value %></div>
      <div class="mt-2 text-sm text-gray-500">
        <%= visualization.counter_aggregation %>(<%= visualization.counter_column %>)
      </div>
    <% end %>
  </div>
<% else %>
  <% config = chart_config_for(visualization, execution) %>
  <% if config.nil? %>
    <p class="rounded border border-gray-200 bg-gray-50 px-4 py-6 text-center text-sm text-gray-500">
      X軸・Y軸を選んでチャートを描画してください。
    </p>
  <% else %>
    <div class="rounded border border-gray-200 bg-white p-4"
         data-controller="chart"
         data-chart-type-value="<%= visualization.chart_type %>"
         data-chart-config-value="<%= config.to_json %>">
      <canvas data-chart-target="canvas"></canvas>
    </div>
  <% end %>
<% end %>
