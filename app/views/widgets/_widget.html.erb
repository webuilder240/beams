<%#
  ダッシュボード上の 1 ウィジェット。タイトル（display_title）・クエリの最新成功結果
  （テーブル/チャートは visualization.display_mode に従う）・「削除」ボタン。
  D&D はドラッグハンドル（⠿）+ SortableJS で実現（トピック19）。
  column_span: 2 は CSS Grid で span 2（widget-span-2 クラス）。
  成功実行が無ければ「未実行」プレースホルダーを表示する。
%>
<% execution = widget.query.latest_succeeded_execution %>
<% visualization = widget.query.visualization %>
<article class="widget-span-<%= widget.column_span %> rounded border border-gray-200 bg-white p-4 space-y-3"
         data-widget-id="<%= widget.id %>">
  <header class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-2">
      <span class="drag-handle cursor-move text-gray-400 select-none" title="ドラッグして並び替え">⠿</span>
      <h2 class="text-base font-semibold text-gray-900">
        <%# turbo_frame "widgets" 内のため _top を指定して frame を抜け全画面遷移する
            （未指定だと遷移先 queries/show に widgets frame が無く Content missing になる） %>
        <%= link_to widget.display_title, query_path(widget.query),
              class: "hover:underline", data: { turbo_frame: "_top" } %>
      </h2>
    </div>
    <div class="flex items-center gap-1 text-xs">
      <%= button_to "削除", dashboard_widget_path(widget.dashboard, widget), method: :delete,
            form: { data: { turbo_confirm: "ウィジェットを削除しますか？" } },
            class: "rounded border border-red-200 px-2 py-1 text-red-600 hover:bg-red-50" %>
    </div>
  </header>

  <% if execution.nil? %>
    <p class="rounded border border-dashed border-gray-300 bg-gray-50 px-4 py-6 text-center text-sm text-gray-500">
      未実行
    </p>
  <% elsif visualization&.display_mode == "chart" %>
    <%= render "visualizations/chart", visualization: visualization, execution: execution %>
  <% else %>
    <%= render "visualizations/result_table", execution: execution %>
  <% end %>
</article>
