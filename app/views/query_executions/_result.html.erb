<%#
  成功実行の結果テーブル。先頭 N 行のみ（result_truncated 時）を表示し、
  全件は CSV ダウンロードへ誘導する。schema/rows は圧縮 blob から復元する。
%>
<% data = execution.result || { schema: [], rows: [] } %>
<div id="query_result" class="space-y-3">
  <% if execution.result_truncated %>
    <div class="rounded bg-amber-50 border border-amber-200 text-amber-800 px-4 py-3 text-sm flex items-center justify-between">
      <span>結果が上限に達したため先頭 <%= data[:rows].size %> 行のみ表示しています。</span>
      <%= link_to "全件はCSVダウンロード",
            latest_csv_query_executions_path(execution.query),
            class: "font-medium underline whitespace-nowrap ml-3" %>
    </div>
  <% end %>

  <div class="flex items-center justify-between text-sm text-gray-600">
    <span><%= execution.result_row_count %> 行</span>
    <%= link_to "CSVダウンロード",
          latest_csv_query_executions_path(execution.query),
          class: "text-blue-600 hover:underline" %>
  </div>

  <div class="overflow-x-auto rounded border border-gray-200">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <% data[:schema].each do |col| %>
            <th class="px-3 py-2 text-left font-medium text-gray-700 whitespace-nowrap">
              <%= col["name"] %>
              <span class="text-xs text-gray-400 font-normal">(<%= col["type"] %>)</span>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% data[:rows].each do |row| %>
          <tr>
            <% row.each do |cell| %>
              <td class="px-3 py-2 whitespace-nowrap font-mono text-gray-800"><%= cell %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
