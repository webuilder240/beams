<%#
  実行履歴の 1 行（トピック17）。collection レンダリング（as: :execution）と、
  ライブ追記の turbo_stream.prepend の両方から再利用する。dom_id で行を識別する。
%>
<% query = local_assigns.fetch(:query)
   latest_succeeded_id = local_assigns[:latest_succeeded_id]
   badge =
     case execution.status
     when "succeeded" then "bg-green-100 text-green-800"
     when "failed" then "bg-red-100 text-red-800"
     when "running" then "bg-blue-100 text-blue-800"
     else "bg-gray-100 text-gray-700"
     end %>
<tr id="<%= dom_id(execution) %>">
  <td class="px-3 py-2 whitespace-nowrap">
    <span class="inline-block rounded px-2 py-0.5 text-xs font-medium <%= badge %>"><%= execution.status %></span>
    <% if execution.failed? && execution.error_message.present? %>
      <p class="mt-1 text-xs text-red-600 whitespace-pre-wrap"><%= execution.error_message %></p>
    <% end %>
  </td>
  <td class="px-3 py-2 whitespace-nowrap text-gray-600">
    <%= execution.started_at ? (l(execution.started_at.in_time_zone, format: :short) rescue execution.started_at) : "—" %>
  </td>
  <td class="px-3 py-2 whitespace-nowrap text-gray-600">
    <%= execution.finished_at ? (l(execution.finished_at.in_time_zone, format: :short) rescue execution.finished_at) : "—" %>
  </td>
  <td class="px-3 py-2 whitespace-nowrap text-gray-600">
    <%= execution.duration ? "#{format('%.1f', execution.duration)} 秒" : "—" %>
  </td>
  <td class="px-3 py-2 whitespace-nowrap text-gray-600">
    <% if execution.succeeded? %>
      <%= execution.result_row_count %> 行<% if execution.result_truncated %> <span class="text-xs text-amber-700">(切り詰め)</span><% end %>
    <% else %>
      —
    <% end %>
  </td>
  <td class="px-3 py-2 whitespace-nowrap text-right space-x-3">
    <% if execution.succeeded_with_result? %>
      <%= link_to "結果を表示", query_execution_path(query, execution),
            class: "text-blue-600 hover:underline",
            data: { turbo_stream: true } %>
      <% if latest_succeeded_id == execution.id %>
        <%= link_to "CSV", latest_csv_query_executions_path(query),
              class: "text-blue-600 hover:underline" %>
      <% end %>
    <% end %>
  </td>
</tr>
