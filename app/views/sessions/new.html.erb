<% content_for :title, "ログイン" %>

<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">ログイン</h1>

  <% if flash[:alert] %>
    <div class="mb-4 rounded bg-red-50 border border-red-200 text-red-700 px-4 py-3">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: session_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "username",
            class: "form-input" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password",
            class: "form-input" %>
    </div>

    <div>
      <%= f.submit "ログイン",
            class: "btn-primary w-full justify-center" %>
    </div>
  <% end %>

  <% if ENV["GOOGLE_OAUTH_CLIENT_ID"].present? %>
    <div class="mt-6 pt-6 border-t border-gray-200">
      <p class="text-sm text-gray-600 mb-3 text-center">または</p>
      <%= button_to "Google でログイン",
            "/auth/google_oauth2",
            method: :post,
            data: { turbo: false },
            class: "btn-secondary w-full justify-center" %>
    </div>
  <% end %>
</div>
