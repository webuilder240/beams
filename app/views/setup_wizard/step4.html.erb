<% content_for :title, "初回セットアップ — コスト上限" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-2">コスト上限の設定（任意）</h1>
  <p class="text-gray-600 mb-6">クエリ単位の課金バイト上限を設定できます。後からでも変更できます。</p>

  <%= render "progress", current: 4 %>

  <%= form_with model: @connection, url: setup_step4_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :maximum_bytes_billed, "コスト上限（バイト）", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :maximum_bytes_billed, min: 1,
            class: "w-full rounded border border-gray-300 px-3 py-2" %>
      <p class="text-xs text-gray-500 mt-1">
        バイト数で入力します（例: 1 TB = 1,000,000,000,000 バイト）。空欄なら上限なしで完了します。
      </p>
    </div>

    <div class="flex items-center gap-4">
      <%= f.submit "保存して完了",
            class: "rounded bg-blue-600 text-white px-4 py-2 font-medium hover:bg-blue-700" %>
      <%= f.submit "スキップして完了",
            class: "rounded bg-gray-200 text-gray-700 px-4 py-2 font-medium hover:bg-gray-300" %>
    </div>
  <% end %>
</div>
