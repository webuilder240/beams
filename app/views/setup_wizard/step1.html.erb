<% content_for :title, "初回セットアップ — 管理者作成" %>

<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-2">ようこそ Beams へ</h1>
  <p class="text-gray-600 mb-6">最初に管理者アカウントを作成します。</p>

  <%= render "progress", current: 1 %>

  <% if @user.errors.any? %>
    <div class="mb-4 rounded bg-red-50 border border-red-200 text-red-700 px-4 py-3">
      <ul class="list-disc list-inside">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: setup_step1_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, "メールアドレス", class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "username",
            class: "w-full rounded border border-gray-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full rounded border border-gray-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "パスワード（確認）", class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full rounded border border-gray-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.submit "管理者を作成して次へ",
            class: "w-full rounded bg-blue-600 text-white px-4 py-2 font-medium hover:bg-blue-700" %>
    </div>
  <% end %>
</div>
