<% content_for :title, "初回セットアップ — BigQuery 接続登録" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-2">BigQuery 接続を登録</h1>
  <p class="text-gray-600 mb-6">サービスアカウント JSON 鍵とプロジェクト ID を入力します。</p>

  <%= render "progress", current: 2 %>

  <% if @connection.errors.any? %>
    <div class="mb-4 rounded bg-red-50 border border-red-200 text-red-700 px-4 py-3">
      <ul class="list-disc list-inside">
        <% @connection.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @connection, url: setup_step2_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, "接続名", class: "form-label" %>
      <%= f.text_field :name, class: "form-input" %>
    </div>

    <div>
      <%= f.label :project_id, "プロジェクト ID", class: "form-label" %>
      <%= f.text_field :project_id, class: "form-input" %>
      <p class="text-xs text-gray-500 mt-1">英数字とハイフンのみ（例: my-project-123）</p>
    </div>

    <div>
      <%= f.label :service_account_json, "サービスアカウント JSON 鍵", class: "form-label" %>
      <%= f.text_area :service_account_json, rows: 8,
            placeholder: "サービスアカウントの JSON 鍵を貼り付けてください",
            class: "form-input font-mono" %>
    </div>

    <div>
      <%= f.submit "接続を登録して次へ",
            class: "btn-primary" %>
    </div>
  <% end %>
</div>
