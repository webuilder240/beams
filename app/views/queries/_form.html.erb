<%#
  local: query, url, method, submit_label, connections
  CodeMirror 6 は Stimulus コントローラ query-editor が
  data-query-editor-target="mount" の div にマウントする。
  エディタの内容は隠しフィールド sql_body（target="input"）に同期される。
  接続は必須（NOT NULL）なので必ず選択させる。接続 0 件なら登録へ誘導。
%>
<% connections ||= Bigquery::Connection.order(:name) %>

<%= render "errors", query: query %>

<% if connections.empty? %>
  <div class="rounded bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 space-y-2">
    <p>クエリの実行先となる BigQuery 接続がありません。先に接続を登録してください。</p>
    <%= link_to "BigQuery 接続を登録", new_bigquery_connection_path,
          class: "inline-block rounded bg-blue-600 text-white px-3 py-2 text-sm font-medium hover:bg-blue-700" %>
  </div>
<% else %>
  <%#
    dry-run（コスト保護★）: 保存済みクエリのときだけ有効化する。
    エンドポイント POST /queries/:id/dry_run が query id を要求するため、
    新規（未保存）では推定表示なし（保存後に推定が走る）。
    dry-run の result/warning/submit ターゲットはフォーム直下に並ぶため、
    コントローラはフォーム要素に付与してそれらを配下に含める（query-editor の
    input textarea も配下にあり、input ターゲットとして共有される）。
  %>
  <% dry_run_enabled = query.persisted? %>
  <% form_data = dry_run_enabled ? { controller: "dry-run", dry_run_url_value: query_dry_run_path(query) } : {} %>
  <%= form_with model: query, url: url, method: method, local: true, class: "space-y-4", data: form_data do |f| %>
    <div>
      <%= f.label :title, "タイトル", class: "form-label" %>
      <%= f.text_field :title, class: "form-input" %>
    </div>

    <div>
      <%= f.label :bigquery_connection_id, "実行先 BigQuery 接続", class: "form-label" %>
      <%= f.collection_select :bigquery_connection_id, connections, :id, :name,
            { prompt: "接続を選択" },
            class: "form-input" %>
    </div>

    <%#
      エディタとスキーマブラウザを同一の data-controller="query-editor" 配下に置く。
      スキーマブラウザのカラム名クリックは `schema-browser:insert`（detail.name）を
      document に dispatch し、query-editor コントローラがカーソル位置に挿入する。
    %>
    <%#
      query-editor の input textarea を dry-run の input target としても共有する。
    %>
    <%= tag.div class: "query-editor flex gap-4", data: { controller: "query-editor" } do %>
      <div class="flex-1 min-w-0">
        <%= f.label :sql_body, "SQL", class: "form-label" %>
        <%#
          隠しフィールド: 実体の sql_body。Stimulus がエディタ変更を同期する。
          JS が無効でも編集できるよう <textarea> をフォールバックにし、
          connect() で非表示にしてエディタをマウントする。
        %>
        <%= f.text_area :sql_body, rows: 12,
              data: dry_run_enabled ? { query_editor_target: "input", dry_run_target: "input" } : { query_editor_target: "input" },
              class: "form-input font-mono" %>
        <div data-query-editor-target="mount" class="query-editor__mount"></div>
      </div>

      <% if local_assigns[:schema].present? %>
        <aside class="query-editor__schema w-72 shrink-0 border-l border-gray-200 pl-4">
          <h2 class="text-sm font-medium mb-2">スキーマ</h2>
          <%= render "schema_browser/schema_browser", connection: query.bigquery_connection, schema: schema %>
        </aside>
      <% end %>
    <% end %>

    <% if dry_run_enabled %>
      <%# 上限超過の警告バナー（dry-run が over_limit を返したら JS が表示） %>
      <div data-dry-run-target="warning" hidden
           class="rounded bg-red-50 border border-red-200 text-red-700 px-4 py-3 text-sm">
        <span data-dry-run-target="warningText"></span>
      </div>
    <% end %>

    <%#
      パラメータプレビュー（09）: SQL の `{{ name }}` 増減に応じて
      parameter-form コントローラがフィールドを描画する。エディタ（query-editor）が
      dispatch する `query-editor:change` を listen する。実行時の本送信は
      show 画面のパラメータフォームで行うため、ここでは入力プレビューのみ。
    %>
    <div data-controller="parameter-form"
         class="rounded border border-dashed border-gray-300 p-4 text-sm text-gray-700">
      <p class="mb-2 text-xs text-gray-500">
        SQL に <code>{{ name }}</code> / <code>{{ name:number }}</code> 等を書くと、ここに実行時パラメータが表示されます。
      </p>
      <div data-parameter-form-target="fields" class="space-y-3"></div>
    </div>

    <div class="flex items-center gap-3">
      <%# 推定スキャン量・コスト表示（dry-run コントローラが更新） %>
      <% if dry_run_enabled %>
        <span data-dry-run-target="result" class="text-sm text-gray-600">推定を計算中…</span>
      <% end %>
      <%= f.submit submit_label,
            data: dry_run_enabled ? { dry_run_target: "submit" } : {},
            class: "btn-primary disabled:opacity-50 disabled:cursor-not-allowed" %>
      <%= link_to "キャンセル", queries_path, class: "text-gray-600 hover:underline" %>
    </div>
  <% end %>
<% end %>
