<% content_for :title, "クエリ一覧" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">クエリ一覧</h1>
    <%= link_to "新規クエリ", new_query_path,
          class: "rounded bg-blue-600 text-white px-4 py-2 text-sm font-medium hover:bg-blue-700" %>
  </div>

  <% if notice %>
    <div class="rounded bg-green-50 border border-green-200 text-green-700 px-4 py-3"><%= notice %></div>
  <% end %>

  <%= form_with url: queries_path, method: :get, local: true, class: "flex items-center gap-2" do |f| %>
    <%= f.search_field :q, value: @q, placeholder: "タイトルで検索",
          class: "w-64 rounded border border-gray-300 px-3 py-2" %>
    <%= f.submit "検索", class: "rounded bg-gray-200 px-3 py-2 text-sm hover:bg-gray-300" %>
  <% end %>

  <% if @queries.empty? %>
    <p class="text-gray-500">クエリがありません。</p>
  <% else %>
    <table class="min-w-full divide-y divide-gray-200 bg-white rounded border border-gray-200">
      <thead>
        <tr class="text-left text-sm text-gray-600">
          <th class="px-4 py-2">タイトル</th>
          <th class="px-4 py-2">接続</th>
          <th class="px-4 py-2">所有者</th>
          <th class="px-4 py-2">更新日時</th>
          <th class="px-4 py-2">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @queries.each do |query| %>
          <tr>
            <td class="px-4 py-2"><%= link_to query.title, query_path(query), class: "text-blue-600 hover:underline" %></td>
            <td class="px-4 py-2"><%= query.bigquery_connection.name %></td>
            <td class="px-4 py-2 text-sm text-gray-500"><%= query.user&.email %></td>
            <td class="px-4 py-2 text-sm text-gray-500"><%= l(query.updated_at.in_time_zone, format: :short) rescue query.updated_at %></td>
            <td class="px-4 py-2 space-x-3 text-sm">
              <%= link_to "編集", edit_query_path(query), class: "text-blue-600 hover:underline" %>
              <%= button_to "削除", query_path(query), method: :delete,
                    form: { data: { turbo_confirm: "本当に削除しますか？" }, class: "inline" },
                    class: "text-red-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
