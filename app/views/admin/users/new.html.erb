<% content_for :title, "新規ユーザー" %>

<div class="max-w-md mx-auto space-y-6">
  <h1 class="text-2xl font-bold">新規ユーザー</h1>

  <%= form_with model: @user, url: admin_users_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <%= render "errors", user: @user %>

    <div>
      <%= f.label :email, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "form-label" %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "form-input" %>
    </div>

    <div>
      <%= f.label :role, "ロール", class: "form-label" %>
      <%= f.select :role, User::ROLES, {}, class: "form-input" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "作成",
            class: "btn-primary" %>
      <%= link_to "キャンセル", admin_users_path, class: "text-gray-600 hover:underline" %>
    </div>
  <% end %>
</div>
