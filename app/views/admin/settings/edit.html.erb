<% content_for :title, "アプリ全体設定" %>

<div class="max-w-md mx-auto space-y-8">
  <h1 class="text-2xl font-bold">アプリ全体設定</h1>

  <% if notice %>
    <div class="rounded bg-green-50 border border-green-200 text-green-700 px-4 py-3"><%= notice %></div>
  <% end %>

  <%= form_with model: @setting, url: admin_settings_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <% if @setting.errors.any? %>
      <div class="rounded bg-red-50 border border-red-200 text-red-700 px-4 py-3">
        <ul class="list-disc list-inside text-sm">
          <% @setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <section class="space-y-2">
      <h2 class="text-lg font-semibold">コスト単価</h2>
      <p class="text-sm text-gray-600">
        クエリのスキャン量（GB）から推定コスト（円）を計算する単価です。
        BigQuery オンデマンドは $6.25/TB ≒ ¥950/TB が目安です（1 TB = 1000 GB 換算）。
      </p>
      <div>
        <%= f.label :bigquery_yen_per_tb, "1 TB あたりの単価（円）", class: "form-label" %>
        <%= f.number_field :bigquery_yen_per_tb, step: "0.01", min: "0",
              class: "form-input" %>
      </div>
    </section>

    <section class="space-y-2">
      <h2 class="text-lg font-semibold">SSO（Google ログイン）</h2>
      <p class="text-sm text-gray-600">
        OAuth 自動プロビジョニングを許可するメールドメインです（例: <code>example.com</code>）。
        空のときは未登録メールでの自動アカウント作成を行いません。
      </p>
      <div>
        <%= f.label :allowed_email_domain, "許可ドメイン", class: "form-label" %>
        <%= f.text_field :allowed_email_domain, placeholder: "example.com",
              autocomplete: "off",
              class: "form-input" %>
      </div>
    </section>

    <div class="flex items-center gap-3">
      <%= f.submit "更新",
            class: "btn-primary" %>
      <%= link_to "戻る", root_path, class: "text-gray-600 hover:underline" %>
    </div>
  <% end %>
</div>
